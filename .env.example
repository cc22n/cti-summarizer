# ── Database ──────────────────────────────────────────────────────────────────
# psycopg v3 driver — do NOT use psycopg2 (encoding issues on Windows)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cti_summarizer

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CTI Source API Keys ───────────────────────────────────────────────────────
# NVD: https://nvd.nist.gov/developers/request-an-api-key (free)
NVD_API_KEY=your_nvd_api_key_here

# AlienVault OTX: https://otx.alienvault.com/api (free)
OTX_API_KEY=your_otx_api_key_here

# ── LLM (xAI Grok) ───────────────────────────────────────────────────────────
# xAI API key: https://x.ai/api
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast

# ── RSS Feed URLs (comma-separated) ──────────────────────────────────────────
RSS_FEED_URLS=https://www.bleepingcomputer.com/feed/,https://krebsonsecurity.com/feed/,https://feeds.feedburner.com/TheHackersNews

# ── Security ──────────────────────────────────────────────────────────────────
# Protects POST endpoints (poll, summarize, generate predictions).
# Leave empty to disable auth in local development.
# Generate in production: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
# Webhook URL for critical alert push notifications (Slack, Discord, n8n, etc.)
# Slack format: https://hooks.slack.com/services/T.../B.../...
# Leave empty to disable.
WEBHOOK_URL=

# ── VirusTotal (IOC enrichment) ───────────────────────────────────────────────
# VirusTotal API key: https://www.virustotal.com/gui/my-apikey
# Requires VT Intelligence for the intelligence search endpoint.
# Skipped silently when empty or when the key lacks Intelligence access.
VIRUSTOTAL_API_KEY=
# Custom VT Intelligence search query (default: positives:10+ tag:malware)
VT_SEARCH_QUERY=positives:10+ tag:malware

# ── Email (weekly executive report) ──────────────────────────────────────────
# SMTP settings for the Monday morning threat report.
# Leave SMTP_HOST empty to disable email reports.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Recipient address for the weekly executive report
REPORT_EMAIL=

# ── Elasticsearch / Logstash / Splunk forwarding ─────────────────────────────
# Point to an Elasticsearch REST endpoint, a Logstash HTTP-input URL, or a
# Splunk HEC-compatible endpoint.  Leave empty to disable event forwarding.
# Examples:
#   ES:       http://localhost:9200
#   Logstash: http://localhost:5044
ELASTICSEARCH_URL=
ELASTICSEARCH_INDEX=cti-alerts

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Comma-separated allowed origins for CORS (frontend URL)
CORS_ORIGINS=http://localhost:5173
